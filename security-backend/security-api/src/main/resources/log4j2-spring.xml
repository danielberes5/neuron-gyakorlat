<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="60">

    <Properties>
        <Property name="log.path">logs</Property>

        <!-- Egységes log pattern -->
        <Property name="pattern">
            %d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level [%marker] [%X{userId}] [%X{correlationId}] %logger{36} - %msg%n
        </Property>
    </Properties>

    <Appenders>

        <!-- Összes alkalmazás log -->
        <RollingFile name="WAREHOUSE_ALL"
                     fileName="${log.path}/warehouse_all.log"
                     filePattern="${log.path}/warehouse_all-%d{yyyy-MM-dd}-%i.log.gz"
                     immediateFlush="true">

            <PatternLayout pattern="${pattern}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>

        </RollingFile>


        <!-- Alkalmazás hibák -->
        <RollingFile name="WAREHOUSE_ERR"
                     fileName="${log.path}/warehouse_err.log"
                     filePattern="${log.path}/warehouse_err-%d{yyyy-MM-dd}-%i.log.gz"
                     immediateFlush="true">

            <PatternLayout pattern="${pattern}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>

            <Filters>
                <ThresholdFilter level="error" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>

        </RollingFile>


        <!-- 3rd party hibák -->
        <RollingFile name="OTHER_ERR"
                     fileName="${log.path}/other_err.log"
                     filePattern="${log.path}/other_err-%d{yyyy-MM-dd}-%i.log.gz"
                     immediateFlush="true">

            <PatternLayout pattern="${pattern}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>

        </RollingFile>

    </Appenders>


    <Loggers>

        <!-- Saját alkalmazás -->
        <Logger name="org.example" level="info" additivity="false">
            <AppenderRef ref="WAREHOUSE_ALL"/>
            <AppenderRef ref="WAREHOUSE_ERR"/>
        </Logger>

        <!-- 3rd party komponensek -->
        <Logger name="org.springframework" level="error" additivity="false">
            <AppenderRef ref="OTHER_ERR"/>
        </Logger>

        <!-- Root -->
        <Root level="info">
            <AppenderRef ref="WAREHOUSE_ALL"/>
        </Root>

    </Loggers>

</Configuration>